        private async Task CargarListaVuelos()
        {
            try
            {
                using (var client = new System.Net.Http.HttpClient())
                {
                    string url = $"{API_BASE}/vuelo?page=1&limit=100";
                    var response = await client.GetStringAsync(url);
                    var parsed = Newtonsoft.Json.Linq.JToken.Parse(response);

                    Newtonsoft.Json.Linq.JArray dataArray = null;

                    // Manejar ambos formatos: array directo o objeto con propiedad "data"
                    if (parsed is Newtonsoft.Json.Linq.JObject jObject)
                    {
                        dataArray = jObject["data"] as Newtonsoft.Json.Linq.JArray;
                    }
                    else if (parsed is Newtonsoft.Json.Linq.JArray jArray)
                    {
                        dataArray = jArray;
                    }

                    vuelosComboBox.Items.Clear();
                    if (dataArray == null) return;

                    foreach (var item in dataArray)
                    {
                        vuelosComboBox.Items.Add(new VueloDto
                        {
                            Id = item["id"]?.ToString(),
                            Nametag = item["nametag"]?.ToString(),
                            Datetime = item["datetime"]?.ToString()
                        });
                    }

                    if (vuelosComboBox.Items.Count > 0)
                        vuelosComboBox.SelectedIndex = 0;
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Error al cargar vuelos: {ex.Message}");
            }
        }

