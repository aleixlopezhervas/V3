        private async Task CargarWaypointsBD(string vueloId)
        {
            try
            {
                using (var client = new System.Net.Http.HttpClient())
                {
                    string url = $"{API_BASE}/instruccion/vuelo?ID_Vuelo={vueloId}";
                    var response = await client.GetStringAsync(url);
                    var parsed = Newtonsoft.Json.Linq.JToken.Parse(response);

                    Newtonsoft.Json.Linq.JArray instrucciones = null;

                    // Manejar ambos formatos
                    if (parsed is Newtonsoft.Json.Linq.JObject jObject)
                    {
                        instrucciones = jObject["data"] as Newtonsoft.Json.Linq.JArray;
                    }
                    else if (parsed is Newtonsoft.Json.Linq.JArray jArray)
                    {
                        instrucciones = jArray;
                    }

                    if (instrucciones == null)
                    {
                        MessageBox.Show("No se pudieron cargar las instrucciones.");
                        return;
                    }

                    var ordenadas = instrucciones
                        .OrderBy(i => (int)(i["trail"] ?? 0))
                        .ToList();

                    // Limpiar estado anterior
                    bdWaypoints.Clear();
                    bdWaypointsListBox.Items.Clear();
                    bdWaypointsOverlay.Markers.Clear();
                    bdWaypointLinesOverlay.Routes.Clear();
                    bdTrace.Clear();
                    bdDroneOverlay.Markers.Clear();
                    bdTraceOverlay.Markers.Clear();

                    int count = 0;
                    foreach (var instruccion in ordenadas)
                    {
                        var punto = instruccion["Punto"];
                        if (punto == null) continue;

                        if (!double.TryParse(punto["Latitud"]?.ToString(),
                                System.Globalization.NumberStyles.Float,
                                System.Globalization.CultureInfo.InvariantCulture, out double lat)) continue;

                        if (!double.TryParse(punto["Longitud"]?.ToString(),
                                System.Globalization.NumberStyles.Float,
                                System.Globalization.CultureInfo.InvariantCulture, out double lon)) continue;

                        count++;
                        var wp = new PointLatLng(lat, lon);
                        bdWaypoints.Add(wp);
                        bdWaypointsListBox.Items.Add($"WP {count}: ({lat:F6}, {lon:F6})");

                        var marker = new WaypointMarker(wp, count);
                        bdWaypointsOverlay.Markers.Add(marker);
                    }

                    // Líneas entre waypoints
                    for (int i = 0; i < bdWaypoints.Count - 1; i++)
                    {
                        var route = new GMapRoute(
                            new List<PointLatLng> { bdWaypoints[i], bdWaypoints[i + 1] }, "route");
                        route.Stroke = new Pen(Color.Blue, 1);
                        bdWaypointLinesOverlay.Routes.Add(route);
                    }

                    bdWaypointsLabel.Text = $"Waypoints ({bdWaypoints.Count})";
                    bdGmap.Refresh();

                    if (bdWaypoints.Count > 0)
                    {
                        bdGmap.Position = bdWaypoints[0];
                        MessageBox.Show($"Cargados {bdWaypoints.Count} waypoints.", "Éxito");
                    }
                    else
                    {
                        MessageBox.Show("Este vuelo no tiene instrucciones con puntos GPS.");
                    }
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Error al cargar instrucciones: {ex.Message}");
            }
        }

