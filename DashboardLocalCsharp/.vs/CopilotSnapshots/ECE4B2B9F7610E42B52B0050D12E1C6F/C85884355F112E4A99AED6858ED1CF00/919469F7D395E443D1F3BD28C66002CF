        private void EnviarDronHacia(double lat, double lon, double alt)
        {
            // Guardar las coordenadas del destino
            destLat = lat;
            destLon = lon;

            // Usar la altitud actual del dron si no se especifica otra
            if (double.IsNaN(currentAlt))
            {
                destAlt = 5; // Altitud por defecto
            }
            else
            {
                destAlt = currentAlt; // Usar altitud actual del dron
            }

            // Intentar llamar al método goto usando reflexión
            try
            {
                var method = dron.GetType().GetMethod("goto");
                if (method != null)
                {
                    // Llamar con: goto(lat, lon, alt, blocking=false)
                    method.Invoke(dron, new object[] { lat, lon, destAlt, false });
                    Console.WriteLine($"Navegando hacia: Lat={lat}, Lon={lon}, Alt={destAlt}");
                    return;
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error al invocar goto: {ex.Message}");
            }

            // Si goto no existe, usar navegación automática con timer
            if (navigationTimer == null)
            {
                navigationTimer = new System.Windows.Forms.Timer();
                navigationTimer.Interval = 500; // Cada 500ms evaluar y ajustar dirección
                navigationTimer.Tick += NavigationTimer_Tick;
            }

            isNavigatingToDestination = true;
            navigationTimer.Start();
            Console.WriteLine($"Iniciando navegación automática hacia: Lat={lat}, Lon={lon}, Alt={destAlt}");
        }

        private void NavigationTimer_Tick(object sender, EventArgs e)
        {
            if (!isNavigatingToDestination || double.IsNaN(currentLatDeg) || double.IsNaN(currentLonDeg) || 
                double.IsNaN(destLat) || double.IsNaN(destLon))
            {
                return;
            }

            // Calcular diferencia en coordenadas
            double dLat = destLat - currentLatDeg;
            double dLon = destLon - currentLonDeg;

            // Si está muy cerca del destino, detener
            if (Math.Abs(dLat) < ARRIVAL_THRESHOLD && Math.Abs(dLon) < ARRIVAL_THRESHOLD)
            {
                isNavigatingToDestination = false;
                navigationTimer.Stop();
                dron.Navegar("Stop");
                Console.WriteLine("Destino alcanzado");
                return;
            }

            // Determinar la dirección de navegación basándose en dLat y dLon
            string direccion = CalcularDireccion(dLat, dLon);
            dron.Navegar(direccion);
        }

        private string CalcularDireccion(double dLat, double dLon)
        {
            // Calcular el ángulo hacia el destino
            double angulo = Math.Atan2(dLon, dLat) * 180 / Math.PI;

            // Normalizar el ángulo a 0-360
            if (angulo < 0) angulo += 360;

            // Determinar la dirección de los 8 puntos cardinales
            // North: -22.5 a 22.5
            // NorthEast: 22.5 a 67.5
            // East: 67.5 a 112.5
            // SouthEast: 112.5 a 157.5
            // South: 157.5 a 202.5
            // SouthWest: 202.5 a 247.5
            // West: 247.5 a 292.5
            // NorthWest: 292.5 a 337.5

            if (angulo >= 337.5 || angulo < 22.5) return "North";
            if (angulo >= 22.5 && angulo < 67.5) return "NorthEast";
            if (angulo >= 67.5 && angulo < 112.5) return "East";
            if (angulo >= 112.5 && angulo < 157.5) return "SouthEast";
            if (angulo >= 157.5 && angulo < 202.5) return "South";
            if (angulo >= 202.5 && angulo < 247.5) return "SouthWest";
            if (angulo >= 247.5 && angulo < 292.5) return "West";
            if (angulo >= 292.5 && angulo < 337.5) return "NorthWest";

            return "Stop";
        }

        private void ActualizarTelemetria(double lat, double lon, double alt, double heading)
        {
            // Actualizar variables internas
            currentLatDeg = lat;
            currentLonDeg = lon;
            currentAlt = alt;
            currentHeading = heading;
            posicionActualizada = true;

            // Actualizar mapa de vuelo en tiempo real cuando está activa la misión
            if (isFlying && flightGmap != null && !double.IsNaN(lat) && !double.IsNaN(lon))
            {
                var dronePos = new PointLatLng(lat, lon);

                // Actualizar o crear marcador del dron en el mapa de vuelo
                if (flightDroneMarker == null)
                {
                    flightDroneMarker = new RedDotMarker(dronePos, 8, heading);
                    flightDroneOverlay.Markers.Add(flightDroneMarker);
                }
                else
                {
                    flightDroneMarker.Position = dronePos;
                    ((RedDotMarker)flightDroneMarker).Heading = heading;
                }

                // Agregar punto al rastro si se ha movido una distancia significativa
                if (flightTrace.Count == 0 || 
                    Math.Abs(flightTrace[flightTrace.Count - 1].Lat - dronePos.Lat) > 0.000001 ||
                    Math.Abs(flightTrace[flightTrace.Count - 1].Lng - dronePos.Lng) > 0.000001)
                {
                    flightTrace.Add(dronePos);

                    // Actualizar el overlay del rastro de forma incremental
                    var traceMarker = new TraceMarker(dronePos);
                    flightTraceOverlay.Markers.Add(traceMarker);
                }

                // Refrescar mapa para mostrar cambios en tiempo real
                flightGmap.Refresh();
            }
        }


