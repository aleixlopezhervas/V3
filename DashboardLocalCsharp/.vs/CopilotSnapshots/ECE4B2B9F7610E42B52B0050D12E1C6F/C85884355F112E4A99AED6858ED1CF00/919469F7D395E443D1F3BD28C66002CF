        private void loadWaypointsBtn_Click(object sender, EventArgs e)
        {
            OpenFileDialog openFileDialog = new OpenFileDialog();
            openFileDialog.Filter = "Archivos de texto (*.txt)|*.txt|Todos los archivos (*.*)|*.*";
            openFileDialog.Title = "Cargar waypoints";

            if (openFileDialog.ShowDialog() == DialogResult.OK)
            {
                try
                {
                    waypoints.Clear();
                    waypointsListBox.Items.Clear();
                    flightWaypointsOverlay.Markers.Clear();
                    flightWaypointLinesOverlay.Markers.Clear();
                    flightWaypointLinesOverlay.Routes.Clear();
                    flightTrace.Clear();
                    flightDroneOverlay.Markers.Clear();

                    string[] lines = File.ReadAllLines(openFileDialog.FileName);
                    int waypointCount = 0;

                    foreach (string line in lines)
                    {
                        string trimmedLine = line.Trim();
                        if (string.IsNullOrEmpty(trimmedLine))
                            continue;

                        string[] parts = trimmedLine.Split(new[] { ',', ' ' }, System.StringSplitOptions.RemoveEmptyEntries);
                        if (parts.Length >= 2 && double.TryParse(parts[0], out double lat) && double.TryParse(parts[1], out double lon))
                        {
                            waypointCount++;
                            waypoints.Add(new PointLatLng(lat, lon));
                            waypointsListBox.Items.Add($"WP {waypointCount}: ({lat:F6}, {lon:F6})");

                            // Agregar marcador personalizado con número
                            var marker = new WaypointMarker(new PointLatLng(lat, lon), waypointCount);
                            flightWaypointsOverlay.Markers.Add(marker);
                        }
                    }

                    // Conectar waypoints con líneas azules finas
                    for (int i = 0; i < waypoints.Count - 1; i++)
                    {
                        // Dibujar línea conectando waypoint actual con el siguiente
                        var route = new GMapRoute(new List<PointLatLng> { waypoints[i], waypoints[i + 1] }, "route");
                        route.Stroke = new Pen(Color.Blue, 1);
                        flightWaypointLinesOverlay.Routes.Add(route);
                    }

                    waypointsLabel.Text = $"Waypoints ({waypoints.Count})";
                    flightGmap.Refresh();

                    if (waypoints.Count > 0)
                    {
                        flightGmap.Position = waypoints[0];
                        MessageBox.Show($"Se cargaron {waypoints.Count} waypoints correctamente.", "Éxito");
                    }
                }
                catch (Exception ex)
                {
                    MessageBox.Show($"Error al cargar el archivo: {ex.Message}", "Error");
                }
            }
        }

        private void startFlightBtn_Click(object sender, EventArgs e)
        {
            if (waypoints.Count == 0)
            {
                MessageBox.Show("Por favor carga waypoints primero.");
                return;
            }

            isFlying = true;
            currentWaypointIndex = 0;
            flightTrace.Clear();
            flightDroneOverlay.Markers.Clear();

            startFlightBtn.Enabled = false;
            loadWaypointsBtn.Enabled = false;

            // Iniciar waypointTimer si no existe
            if (waypointTimer == null)
            {
                waypointTimer = new System.Windows.Forms.Timer();
                waypointTimer.Interval = 500; // Cada 500ms evaluar waypoint
                waypointTimer.Tick += WaypointTimer_Tick;
            }

            waypointTimer.Start();

            // Enviar al primer waypoint
            if (currentWaypointIndex < waypoints.Count)
            {
                var wp = waypoints[currentWaypointIndex];
                dron.IrAlPunto((float)wp.Lat, (float)wp.Lng, FLIGHT_ALTITUDE);
                Console.WriteLine($"Enviando al waypoint {currentWaypointIndex + 1}/{waypoints.Count}: ({wp.Lat}, {wp.Lng})");
            }
        }

        private void stopFlightBtn_Click(object sender, EventArgs e)
        {
            isFlying = false;
            if (waypointTimer != null)
                waypointTimer.Stop();

            dron.Navegar("Stop");
            startFlightBtn.Enabled = true;
            loadWaypointsBtn.Enabled = true;
            currentWaypointIndex = 0;

            // Limpiar rastro y dron del mapa
            flightTrace.Clear();
            flightDroneOverlay.Markers.Clear();
            flightTraceOverlay.Markers.Clear();
            flightGmap.Refresh();

            Console.WriteLine("Vuelo detenido.");
        }

        private void WaypointTimer_Tick(object sender, EventArgs e)
        {
            if (!isFlying || currentWaypointIndex >= waypoints.Count)
            {
                isFlying = false;
                waypointTimer.Stop();
                startFlightBtn.Enabled = true;
                loadWaypointsBtn.Enabled = true;

                Console.WriteLine("Vuelo completado.");
                MessageBox.Show("Vuelo completado - Todos los waypoints alcanzados.");

                // Limpiar rastro DESPUÉS de que el usuario acepta el diálogo
                flightTrace.Clear();
                flightDroneOverlay.Markers.Clear();
                flightTraceOverlay.Markers.Clear();
                flightGmap.Refresh();

                return;
            }

            // Comprobar si hemos llegado al waypoint actual
            if (double.IsNaN(currentLatDeg) || double.IsNaN(currentLonDeg))
                return;

            var currentWaypoint = waypoints[currentWaypointIndex];
            double dLat = Math.Abs(currentLatDeg - currentWaypoint.Lat);
            double dLon = Math.Abs(currentLonDeg - currentWaypoint.Lng);

            // Si está muy cerca del waypoint actual, ir al siguiente
            if (dLat < WAYPOINT_ARRIVAL_THRESHOLD && dLon < WAYPOINT_ARRIVAL_THRESHOLD)
            {
                currentWaypointIndex++;
                if (currentWaypointIndex < waypoints.Count)
                {
                    var nextWp = waypoints[currentWaypointIndex];
                    dron.IrAlPunto((float)nextWp.Lat, (float)nextWp.Lng, FLIGHT_ALTITUDE);
                    Console.WriteLine($"Waypoint {currentWaypointIndex} alcanzado. Enviando al waypoint {currentWaypointIndex + 1}/{waypoints.Count}: ({nextWp.Lat}, {nextWp.Lng})");
                    waypointsListBox.SelectedIndex = currentWaypointIndex;
                }
            }
        }

